# Copy to .env and fill in your API keys

# Required for Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Required for OpenAI (GPT-4, etc.)
# OPENAI_API_KEY=sk-...

# Required for OpenRouter (200+ open-source models)
# OPENROUTER_API_KEY=sk-or-...

# Required for Groq
# GROQ_API_KEY=...

# Server port
GOOEY_PORT=4242
